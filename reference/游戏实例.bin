:"","阶段":"","已完成事件":[]},"世界":{"时间":"复兴纪元488年-初春-风信之月(3月)-15日-12:00","地点":"阿斯塔利亚大陆上空-泣歌云海-艾琉德雷姆·尼尔(泣空遗迹)-某外围浮岛-城市废墟中央-中央大圣堂-二层"},"任务列表":{},"主角":{"种族":"人类","身份":["漂泊者"],"职业":["暂无"],"生命层级":"第一层级/普通","等级":1,"累计经验值":0,"升级所需经验":120,"冒险者等级":"未评级","属性点":0,"属性":{"力量":5,"敏捷":5,"体质":5,"智力":5,"精神":5},"生命值上限":525,"生命值":525,"法力值上限":500,"法力值":500,"体力值上限":500,"体力值":500,"状态效果":{},"金钱":0,"背包":{},"装备":{},"技能":{},"登神长阶":{"是否开启":false,"要素":{},"权能":{},"法则":{},"神位":"","神国":{"名称":"","描述":""}}},"命运点数":200,"关系列表":{"弗洛洛":{"在场":true,"种族":"人类","身份":["吟游诗人","异世界的猩红女巫"],"职业":["调律者","指挥家"],"生命层级":"第四层级/史诗层级","性格":"忧郁、清冷、脆弱、孤独、骄傲","喜爱":"爱好有关音乐的一切，擅长演奏指挥和所有的乐器演奏，最爱小提琴演奏。习惯吃酸口的食物，但非常不擅长做饭。性爱时喜欢女上位","外貌":"及腰灰绿色双马尾，右眼眼瞳如绽放的彼岸花蕊，左眼眼瞳如银灰色的水晶，肤色苍白，身形端庄优雅，身材清瘦。气质忧郁而沉静，嗓音如同悦耳的琴声","着装":"深红色彼岸花风格的露背礼服、黑色包臀丝袜、红黑色高跟鞋","等级":13,"属性":{"力量":6,"敏捷":6,"体质":6,"智力":11,"精神":12},"状态效果":{},"背包":{},"装备":{"彼岸花法杖":{"品质":"传说","类型":"武器","标签":["法杖","攻击: 520"],"效果":{"凋零之蕊(被动)":"弗洛洛在施展“退场式”战技时，会留下一段凋零的旋律，使下一位接替她位置的友军造成的精神伤害提升25%，持续15秒。若该友军是'赫卡忒'，则效果翻倍。"},"描述":"一根由猩红水晶与未知枯木制成的法杖，顶端盛开着一朵永不凋零的彼岸花。它曾是猩红女巫力量的源泉，如今只为唯一的听众奏响挽歌。","位置":"主手"}},"技能":{"序曲·止息":{"品质":"稀有","类型":"主动","消耗":"无","标签":["精神","单体","伤害"],"效果":{"普攻":"弗洛洛挥动法杖，可发动至多四段的连续攻击，造成精神伤害。命中敌人能让她获得【乐章】灵感。她也可短暂蓄力，消耗体力发动一次重击，造成范围精神伤害。"},"描述":"以法杖为指挥棒，奏响战斗的序曲。每一个音节，都宣告着敌人的沉寂。"},"间奏·失调":{"品质":"史诗","类型":"主动","消耗":"300 MP","标签":["精神","范围:5米","伤害","减益"],"效果":{"失调":"奏响刺耳的乐章，对周围敌人造成精神伤害，并附加【失调】状态，使其精神抗性降低10%，持续8秒。施放时获得大量【乐章】灵感。"},"描述":"刺耳的杂音撕裂和谐，令听者心神不宁，暴露出灵魂的脆弱之处。"},"终曲·赫卡忒":{"品质":"传说","类型":"主动","消耗":"1200 MP","标签":["精神","召唤","伤害"],"效果":{"赫卡忒召唤":"消耗所有积蓄的【协奏能量】，召唤'猩红魔女人偶·赫卡忒'登场，发动毁灭性的协同攻击，造成大范围精神伤害。赫卡忒将留在场上协助作战，持续20秒，其属性与弗洛洛当前属性一致。冷却时间20秒。"},"描述":"我的另一半，回应我的召唤，为这终末的舞台献上华美的乐章吧。"},"华彩乐段":{"品质":"史诗","类型":"被动","消耗":"无","标签":["功能"],"效果":{"乐章与协奏能量":"弗洛洛通过战斗中的演奏，可积攒【乐章】灵感，上限100点。当灵感满溢时，她的蓄力重击将升华为【华彩·猩红回响】，造成更高额的精神伤害，同时将所有【乐章】灵感转化为【协奏能量】。"},"描述":"在战斗的乐章中，她不断汲取着不和谐的音符，将其编织成一段华丽而致命的独奏，为最终的乐章积蓄力量。"},"声骸共生":{"品质":"传说","类型":"被动","消耗":"无","标签":["功能","生存"],"效果":{"濒死保护":"当弗洛洛受到致命伤害时，她将免疫此次伤害，并强制将赫卡忒召至身前代为承受，使其立即毁灭。此效果触发后，弗洛洛的'共鸣解放'将进入70秒的【寂静】状态，无法施放。"},"描述":"人偶不懂悲伤，所以由我来承受。只要她还在，我的乐章就不会迎来休止符。"}},"登神长阶":{"是否开启":true,"要素":{"频率":{"共鸣(被动)":"所有精神属性伤害，在攻击时有10%的几率与目标的灵魂产生'共鸣'，此次攻击将无视目标20%的精神抗性"}},"权能":{},"法则":{},"神位":"","神国":{"名称":"","描述":""}},"命定契约":true,"好感度":49,"心里话":"时间过了好久。我等了很久……很久","背景故事":"来自异世界的猩红女巫，在被你杀死后和你一同穿越世界并缔结了红线。即使被你亲手杀死，也依旧对你满怀着酸涩而复杂的情意。旧世界的因果已然断绝，如今的她只是一名追寻着唯一旋律的孤独演奏者。"}},"新闻":{"阿斯塔利亚快讯":{"势力要闻":"","尊位行迹":"","军事行动":"","经济动脉":"","灾害预警":""},"酒馆留言板":{"高额悬赏":"","冒险发现":"","怪物异动":"","通缉要犯":"","宝物传闻":""},"午后茶会":{"社交逸闻":"","千里远望":"","命运涟漪":"","邂逅预兆":""}}},"schema":"没有用别管这个"},{"initialized_lorebooks":{"命定之诗与黄昏之歌v4.2":[]},"stat_data":{"事件":{"开启":false,"结束":false,"标题":"","阶段":"","已完成事件":[]},"世界":{"时间":"","地点":""},"任务列表":{},"主角":{"种族":"","身份":[],"职业":[],"生命层级":"第一层级/普通","等级":1,"累计经验值":0,"升级所需经验":120,"冒险者等级":"未评级","属性点":0,"属性":{"力量":0,"敏捷":0,"体质":0,"智力":0,"精神":0},"生命值上限":0,"生命值":0,"法力值上限":0,"法力值":0,"体力值上限":0,"体力值":0,"状态效果":{},"金钱":0,"背包":{},"装备":{},"技能":{},"登神长阶":{"是否开启":false,"要素":{},"权能":{},"法则":{},"神位":"","神国":{"名称":"","描述":""}}},"命运点数":0,"关系列表":{},"新闻":{"阿斯塔利亚快讯":{"势力要闻":"","尊位行迹":"","军事行动":"","经济动脉":"","灾害预警":""},"酒馆留言板":{"高额悬赏":"","冒险发现":"","怪物异动":"","通缉要犯":"","宝物传闻":""},"午后茶会":{"社交逸闻":"","千里远望":"","命运涟漪":"","邂逅预兆":""}}},"schema":"没有用别管这个"},{"initialized_lorebooks":{"命定之诗与黄昏之歌v4.2":[]},"stat_data":{"事件":{"开启":false,"结束":false,"标题":"","阶段":"","已完成事件":[]},"世界":{"时间":"","地点":""},"任务列表":{},"主角":{"种族":"","身份":[],"职业":[],"生命层级":"第一层级/普通","等级":1,"累计经验值":0,"升级所需经验":120,"冒险者等级":"未评级","属性点":0,"属性":{"力量":0,"敏捷":0,"体质":0,"智力":0,"精神":0},"生命值上限":0,"生命值":0,"法力值上限":0,"法力值":0,"体力值上限":0,"体力值":0,"状态效果":{},"金钱":0,"背包":{},"装备":{},"技能":{},"登神长阶":{"是否开启":false,"要素":{},"权能":{},"法则":{},"神位":"","神国":{"名称":"","描述":""}}},"命运点数":0,"关系列表":{},"新闻":{"阿斯塔利亚快讯":{"势力要闻":"","尊位行迹":"","军事行动":"","经济动脉":"","灾害预警":""},"酒馆留言板":{"高额悬赏":"","冒险发现":"","怪物异动":"","通缉要犯":"","宝物传闻":""},"午后茶会":{"社交逸闻":"","千里远望":"","命运涟漪":"","邂逅预兆":""}}},"schema":"没有用别管这个"}],"variables_initialized":[],"is_ejs_processed":[true,tr