    },
    {
      "id": "mem-turn-5",
      "saveId": "save-progressive",
      "createdAt": 1782312963356,
      "realTimestamp": 1782312963356,
      "timeRange": {
        "start": "复兴纪元488年-08月-15日-20:45",
        "end": "复兴纪元488年-08月-15日-21:00"
      },
      "content": "柠萌茶确认绮萝莉娅是教团最强者。绮萝莉娅表示从未想过当教主。柠萌茶带她去浴室清洗时，绮萝莉娅透露无法感知身体触觉，但身体对语言指令有反应。柠萌茶对这种灵肉分离的现象十分好奇。",
      "hiddenLine": "确认实力背景，发现身体对语言反应的现象",
